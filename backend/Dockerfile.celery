FROM python:3.12-slim

WORKDIR /app

COPY api-gateway/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ /app/backend/shared/
COPY services/ /app/backend/services/

ENV PYTHONPATH=/app

CMD ["celery", "-A", "backend.shared.utils.celery_app", "worker", "--loglevel=info", "--concurrency=4"]
