# =============================================================================
# StablePay - SME Economic Infrastructure Platform
# Environment Configuration Template
# =============================================================================

# --- General ---
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
PROJECT_NAME=StablePay
VERSION=0.1.0

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://stablepay:stablepay@localhost:5432/stablepay
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Auth (Clerk / Supabase / Auth0) ---
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- API Gateway ---
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_PER_MINUTE=100

# --- Blockchain (Polygon) ---
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
CONTRACT_DEPLOYER_PRIVATE_KEY=
USDC_CONTRACT_ADDRESS=
AE_COIN_CONTRACT_ADDRESS=
PAYMENT_CONTRACT_ADDRESS=
TRADE_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
CHAIN_ID=137

# --- Services ---
TREASURY_SERVICE_URL=http://treasury-service:8002
PAYMENTS_SERVICE_URL=http://payments-service:8003
TRADE_SERVICE_URL=http://trade-service:8004
COMPLIANCE_SERVICE_URL=http://compliance-service:8005
SCORING_SERVICE_URL=http://scoring-service:8006
INTEGRATIONS_SERVICE_URL=http://integrations-service:8007

# --- Storage ---
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=stablepay-documents

# --- Email / SMS ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@stablepay.io
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AI / ML ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_PROVIDER=openai
FRAUD_MODEL_PATH=ai/models/fraud/model.pkl
CREDIT_MODEL_PATH=ai/models/credit/model.pkl
CASHFLOW_MODEL_PATH=ai/models/cashflow/model.pkl

# --- Compliance ---
KYB_PROVIDER=placeholder
AML_PROVIDER=placeholder
SANCTIONS_LIST_PATH=ai/data/sanctions/sdn_list.csv

# --- Integrations ---
ERP_INTEGRATION=placeholder
BANKING_API_KEY=
BANKING_API_SECRET=
BANKING_BASE_URL=
WEBHOOK_SECRET=change-me-in-production

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
